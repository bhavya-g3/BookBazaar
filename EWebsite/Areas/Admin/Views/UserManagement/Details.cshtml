@model UserDetailsVM
@using EWebsite

@{
    ViewData["Title"] = "User Details";
    var isAdmin = Model.RoleNames.Contains(Roles.Role_Admin, StringComparer.OrdinalIgnoreCase);
}

<h2>User Details</h2>
<partial name="_Notification" />

<div class="container">

    <div class="row pt-3">
        <div class="col-md-8">

            <div class="card mb-3">
                <div class="card-header bg-primary text-white">
                    Basic Information
                </div>

                <div class="card-body">
                    <dl class="row">

                        <dt class="col-sm-3">Email</dt>
                        <dd class="col-sm-9">@Model.Email</dd>

                        <dt class="col-sm-3">UserName</dt>
                        <dd class="col-sm-9">@Model.UserName</dd>

                        <dt class="col-sm-3">Roles</dt>
                        <dd class="col-sm-9">
                            @(Model.RoleNames.Any() ? string.Join(", ", Model.RoleNames) : "Customer")
                        </dd>

                    </dl>

                    <div class="mt-3">
                        @if (isAdmin)
                        {
                            if (!Model.IsProtected)
                            {
                                <form asp-area="Admin"
                                      asp-controller="UserManagement"
                                      asp-action="DemoteToCustomer"
                                      method="post"
                                      class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="userId" value="@Model.Id" />
                                    <button type="submit" class="btn btn-warning">Make Customer</button>
                                </form>
                            }
                        }
                        else
                        {
                            <form asp-area="Admin"
                                  asp-controller="UserManagement"
                                  asp-action="PromoteToAdmin"
                                  method="post"
                                  class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="userId" value="@Model.Id" />
                                <button type="submit" class="btn btn-primary">Make Admin</button>
                            </form>
                        }
                        <a asp-area="Admin"
                           asp-controller="UserManagement"
                           asp-action="UserManage"
                           class="btn btn-secondary ms-2">
                            Back to list
                        </a>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header bg-light">
                    Shipping Address
                </div>

                <div class="card-body">
                    @if (!string.IsNullOrWhiteSpace(Model.Name))
                    {
                        <dl class="row">

                            <dt class="col-sm-3">Name</dt>
                            <dd class="col-sm-9">@Model.Name</dd>

                            <dt class="col-sm-3">Phone</dt>
                            <dd class="col-sm-9">@Model.Phone</dd>

                            <dt class="col-sm-3">Street</dt>
                            <dd class="col-sm-9">@Model.StreetAddress</dd>

                            <dt class="col-sm-3">City</dt>
                            <dd class="col-sm-9">@Model.City</dd>

                            <dt class="col-sm-3">State</dt>
                            <dd class="col-sm-9">@Model.State</dd>

                            <dt class="col-sm-3">Postal Code</dt>
                            <dd class="col-sm-9">@Model.PostalCode</dd>

                        </dl>
                    }
                    else
                    {
                        <p class="text-muted mb-0">No shipping address on file.</p>
                    }
                </div>
            </div>

        </div>
    </div>

</div>