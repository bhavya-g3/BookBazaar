@using EWebsite.Models
@model IEnumerable<ProductBG>

@{
    ViewData["Title"] = "Home Page";
}

<div class="container py-4">

    <h2 class="mb-4">Latest Products</h2>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">No Products available yet.</div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var p in Model)
            {
                <div class="col-12 col-sm-6 col-md-4 col-lg-2 col-xl-2">
                    <div class="card h-100 shadow-sm">

                        <img class="card-img-top"
                             src="@(string.IsNullOrWhiteSpace(p.ImageURL)
                                                                 ? Url.Content("~/images/product/placeholder.png")
                                                                 : Url.Content(p.ImageURL))"
                     alt="@p.Title"
                     asp-append-version="true"
                     style="width:100%;aspect-ratio:2/3;object-fit:cover;
                                    display:block;border-top-left-radius:.5rem;
                                    border-top-right-radius:.5rem;" />

                        <div class="card-body d-flex flex-column">

                            <h5 class="card-title text-truncate" title="@p.Title">
                                @p.Title
                            </h5>

                            <p class="card-text mb-2">
                                <span class="fw-semibold">@p.Price</span>
                            </p>

                            <div class="mt-auto">

                                <p class="text-muted small mb-3 text-truncate" title="@p.Author">
                                    @p.Author
                                </p>

                                <p class="text-dark text-opacity-75 text-center lg-0">
                                    <span class="text-decoration-line-through">
                                        List Price:
                                        @p.ListPrice.ToString("c")
                                    </span>
                                </p>

                                <p class="text-dark text-opacity-75 text-center">
                                    As low as:
                                    <span>@p.Price100.ToString("c")</span>
                                </p>

                                <div class="mt-auto d-flex gap-2">
                                    <a asp-action="Details"
                                       asp-route-id="@p.Id"
                                       class="btn btn-outline-primary btn-sm">
                                        Details
                                    </a>
                                </div>

                            </div>
                        </div>

                    </div>
                </div>
                }
        </div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}