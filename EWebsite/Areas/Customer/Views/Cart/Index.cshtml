@model EWebsite.Areas.Customer.Controllers.CartController.CartIndexVM

@{
    ViewData["Title"] = "Your Cart";
}

<h2 class="mt-3 mb-3">Your Cart</h2>

<partial name="_Notification" />

@if (Model.Lines == null || !Model.Lines.Any())
{
    <div class="alert alert-info">Your cart is empty.</div>

    <a asp-area="Customer" asp-controller="Home" asp-action="Index"
       class="btn btn-outline-primary">
        Continue Shopping
    </a>
}
else
{
    <div class="table-responsive">
        <table class="table align-middle">
            <thead class="table-light">
                <tr>
                    <th>Product</th>
                    <th style="width:140px;">Unit Price</th>
                    <th style="width:120px;">Qty</th>
                    <th style="width:140px;">Subtotal</th>
                    <th style="width:120px;"></th>
                </tr>
            </thead>

            <tbody>
                @foreach (var line in Model.Lines)
                {
                    <tr>
                        <td>
                            <div class="d-flex align-items-center gap-3">
                                <img src="@line.ImageURL"
                                     alt="@line.Title"
                                     style="width:64px;height:64px;object-fit:cover;"
                                     class="rounded border" />

                                <div>
                                    <div class="fw-semibold">@line.Title</div>
                                    <div class="text-muted small">ID: @line.ProductId</div>

                                    @if (line.MaxQuantityPerOrder is not null)
                                    {
                                        <div class="badge bg-light text-dark border small">
                                            Max per order: @line.MaxQuantityPerOrder
                                        </div>
                                    }

                                    @if (line.MaxQuantityPerOrder is not null && line.Count >= line.MaxQuantityPerOrder)
                                    {
                                        <div class="text-warning small mt-1">
                                            You’ve reached the max allowed for this product.
                                        </div>
                                    }
                                </div>
                            </div>
                        </td>

                        <td>@line.UnitPrice.ToString("c")</td>
                        <td>@line.Count</td>
                        <td>@line.Subtotal.ToString("c")</td>

                        <td>
                            <form method="post"
                                  asp-area="Customer"
                                  asp-controller="Cart"
                                  asp-action="Remove"
                                  onsubmit="return confirm('Are you sure you want to remove this item?');"
                                  class="d-inline">

                                @Html.AntiForgeryToken()

                                <input type="hidden" name="productId" value="@line.ProductId" />

                                <button type="submit"
                                        class="btn btn-outline-danger btn-sm">
                                    Remove
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>

            <tfoot>
                <tr>
                    <td colspan="3" class="text-end fw-semibold">Total:</td>
                    <td class="fw-bold">
                        @Model.Total.ToString("c")
                    </td>
                    <td></td>
                </tr>
            </tfoot>
        </table>
    </div>

    <div class="d-flex justify-content-between">

        <a asp-area="Customer"
           asp-controller="Home"
           asp-action="Index"
           class="btn btn-outline-secondary">
            Continue Shopping
        </a>

        <a asp-area="Customer"
           asp-controller="Checkout"
           asp-action="Shipping"
           class="btn btn-primary">
            Proceed to Checkout
        </a>
    </div>
}